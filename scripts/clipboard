#!/bin/bash
# SSH Clipboard Integration with OSC52 support
# Usage: echo "text" | clipboard
# Usage: clipboard "text"
# Usage: clipboard < file.txt

if [ $# -gt 0 ]; then
    # Text provided as argument
    text="$*"
else
    # Read from stdin
    text=$(cat)
fi

# Generate OSC52 sequence for tmux/terminal clipboard
osc52_sequence="$(printf "\033]52;c;%s\007" "$(printf "%s" "$text" | base64 | tr -d '\n')")"

# Send to clipboard using OSC52
printf "%s" "$osc52_sequence"

# Also try system clipboard if available
if command -v xclip >/dev/null 2>&1; then
    printf "%s" "$text" | xclip -selection clipboard
elif command -v pbcopy >/dev/null 2>&1; then
    printf "%s" "$text" | pbcopy
fi

# Feedback
echo "📋 Copied to clipboard: ${text:0:50}" >&2
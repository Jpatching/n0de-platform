// PV3 Platform - Complete Prisma Schema
// Shared between Backend (Railway) and Frontend (Vercel)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core User Model
model User {
  id        String   @id @default(cuid())
  wallet    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Profile information
  username  String?  @unique
  avatar    String?
  email     String?
  displayName String?
  bio       String?
  
  // Privacy settings
  showUsername Boolean @default(true)
  profileVisibility String @default("public") // public, friends, private
  
  // Security & 2FA
  twoFactorEnabled         Boolean   @default(false)
  twoFactorSecret          String?   // Hashed TOTP secret
  backupCodes              String?   // Hashed backup codes
  lastTwoFactorVerification DateTime?
  
  // Stats
  totalEarnings Float   @default(0)
  totalMatches  Int     @default(0)
  wins          Int     @default(0)
  losses        Int     @default(0)
  winRate       Float   @default(0)
  
  // Reputation & Achievements
  reputation    Int     @default(1000)
  achievements  Json?
  badges        Json?
  
  // Preferences
  preferences   Json?
  
  // Relationships
  matches1      Match[] @relation("Player1")
  matches2      Match[] @relation("Player2")
  tournaments   TournamentParticipant[]
  referrals     Referral[] @relation("Referrer")
  referred      Referral[] @relation("Referred")
  bridgeTransactions BridgeTransaction[]
  securityLogs  SecurityLog[]
  
  // Performance indexes
  @@index([totalEarnings(sort: Desc)])
  @@index([wins(sort: Desc)])
  @@index([winRate(sort: Desc)])
  @@index([reputation(sort: Desc)])
  @@index([createdAt])
  @@index([twoFactorEnabled])
  @@index([lastTwoFactorVerification])
  @@map("users")
}

// Match System
model Match {
  id        String   @id @default(cuid())
  gameType  String
  wager     Float
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  startedAt DateTime?
  endedAt   DateTime?
  
  // Players
  player1Id String
  player2Id String?
  winnerId  String?
  
  // Game data
  gameData  Json?
  result    Json?
  signature String?
  
  // Solana integration
  escrowAddress String?
  transactionId String?
  
  player1   User @relation("Player1", fields: [player1Id], references: [id])
  player2   User? @relation("Player2", fields: [player2Id], references: [id])
  
  // Performance indexes
  @@index([status])
  @@index([gameType])
  @@index([createdAt(sort: Desc)])
  @@index([player1Id])
  @@index([player2Id])
  @@index([wager(sort: Desc)])
  @@map("matches")
}

// Tournament System
model Tournament {
  id          String   @id @default(cuid())
  name        String
  description String?
  prizePool   Float
  status      String   @default("upcoming")
  maxPlayers  Int
  currentPlayers Int   @default(0)
  createdAt   DateTime @default(now())
  startsAt    DateTime
  endsAt      DateTime?
  
  // Tournament configuration
  gameType    String
  entryFee    Float
  format      String   @default("single_elimination")
  rules       Json?
  
  participants TournamentParticipant[]
  
  // Performance indexes
  @@index([status])
  @@index([gameType])
  @@index([startsAt])
  @@index([prizePool(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("tournaments")
}

model TournamentParticipant {
  id           String @id @default(cuid())
  tournamentId String
  userId       String
  joinedAt     DateTime @default(now())
  eliminated   Boolean  @default(false)
  placement    Int?
  
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
  
  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([userId])
  @@map("tournament_participants")
}

// Referral System
model Referral {
  id         String   @id @default(cuid())
  code       String   @unique
  referrerId String
  referredId String?
  createdAt  DateTime @default(now())
  claimedAt  DateTime?
  
  // Rewards
  totalEarnings Float @default(0)
  totalRewards  Float @default(0)
  
  referrer   User @relation("Referrer", fields: [referrerId], references: [id])
  referred   User? @relation("Referred", fields: [referredId], references: [id])
  
  // Performance indexes
  @@index([referrerId])
  @@index([totalEarnings(sort: Desc)])
  @@index([createdAt])
  @@map("referrals")
}

// Leaderboards
model Leaderboard {
  id        String   @id @default(cuid())
  type      String   // "earnings", "wins", "winrate"
  period    String   // "daily", "weekly", "monthly", "alltime"
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([type, period])
  @@index([type])
  @@index([period])
  @@index([updatedAt])
  @@map("leaderboards")
}

// Security & Audit
model SecurityLog {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  action    String
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  
  // Additional fields for analytics
  eventType String?  // For categorizing security events
  metadata  Json?    // For storing additional structured data
  
  // User relationship
  user      User?    @relation(fields: [userId], references: [id])
  
  // Performance indexes
  @@index([userId])
  @@index([type])
  @@index([eventType])
  @@index([createdAt(sort: Desc)])
  @@index([ipAddress])
  @@map("security_logs")
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String?
  action     String
  targetType String?
  targetId   String?
  details    Json?
  createdAt  DateTime @default(now())
  
  // Performance indexes
  @@index([adminId])
  @@index([action])
  @@index([targetType])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

// Analytics
model Analytics {
  id        String   @id @default(cuid())
  type      String
  period    String   // "hourly", "daily", "weekly"
  data      Json
  createdAt DateTime @default(now())
  
  @@unique([type, period, createdAt])
  @@index([type])
  @@index([period])
  @@index([createdAt(sort: Desc)])
  @@map("analytics")
}

// Bridge System
model BridgeTransaction {
  id            String   @id @default(cuid())
  userId        String
  sourceChain   String
  targetChain   String
  sourceToken   String
  targetToken   String
  amount        Float
  bridgeFee     Float    @default(0)
  convenienceFee Float   @default(0)
  netAmount     Float
  status        String   @default("pending") // pending, bridging, completed, failed
  
  // Transaction hashes
  sourceTxHash  String?
  targetTxHash  String?
  vaaId         String?
  
  // Timestamps
  createdAt     DateTime @default(now())
  completedAt   DateTime?
  
  // User relationship
  user          User     @relation(fields: [userId], references: [id])
  
  // Fee collections relationship
  feeCollections BridgeFeeCollection[]
  
  // Performance indexes
  @@index([userId])
  @@index([status])
  @@index([sourceChain])
  @@index([createdAt(sort: Desc)])
  @@index([sourceTxHash])
  @@map("bridge_transactions")
}

model BridgeFeeCollection {
  id            String   @id @default(cuid())
  bridgeId      String
  feeAmount     Float
  feeType       String   // "convenience", "gas_reimbursement"
  collectedAt   DateTime @default(now())
  
  bridge        BridgeTransaction @relation(fields: [bridgeId], references: [id])
  
  @@index([bridgeId])
  @@index([collectedAt])
  @@index([feeType])
  @@map("bridge_fee_collections")
}

// Developer System
model Developer {
  id              String   @id @default(cuid())
  walletAddress   String   @unique
  registeredAt    DateTime @default(now())
  status          String   @default("active") // active, suspended, banned
  
  // Stats
  totalRevenue    Float    @default(0)
  totalProjects   Int      @default(0)
  approvedProjects Int     @default(0)
  
  // Profile
  name            String?
  email           String?
  website         String?
  bio             String?
  
  // Relationships
  projects        DeveloperProject[]
  
  @@index([walletAddress])
  @@index([status])
  @@index([registeredAt])
  @@map("developers")
}

model DeveloperProject {
  id              String   @id @default(cuid())
  developerId     String
  name            String
  description     String
  gameType        String
  status          String   @default("draft") // draft, submitted, under_review, approved, live, rejected
  
  // Submission details
  repositoryUrl   String?
  demoUrl         String?
  documentation   String?
  contactEmail    String
  
  // Review process
  submittedAt     DateTime?
  reviewedAt      DateTime?
  reviewNotes     String?
  reviewedBy      String?
  adminFeedback   String?
  rejectionReason String?
  
  // Approval workflow
  internalNotes   String?
  priority        String   @default("normal") // low, normal, high, urgent
  estimatedReviewTime String?
  
  // Live stats
  revenue         Float    @default(0)
  players         Int      @default(0)
  matches         Int      @default(0)
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relationships
  developer       Developer @relation(fields: [developerId], references: [id])
  
  @@index([developerId])
  @@index([status])
  @@index([gameType])
  @@index([submittedAt])
  @@index([priority])
  @@map("developer_projects")
}

// Admin System for Developer Hub
model Admin {
  id              String   @id @default(cuid())
  walletAddress   String   @unique
  username        String   @unique
  role            String   @default("reviewer") // reviewer, moderator, admin, super_admin
  permissions     Json?    // Specific permissions array
  
  // Profile
  name            String?
  email           String?
  avatar          String?
  
  // Activity tracking
  isActive        Boolean  @default(true)
  lastLogin       DateTime?
  createdAt       DateTime @default(now())
  
  // Review stats
  totalReviews    Int      @default(0)
  approvedProjects Int     @default(0)
  rejectedProjects Int     @default(0)
  
  @@index([walletAddress])
  @@index([role])
  @@index([isActive])
  @@map("admins")
}

// Project Review History
model ProjectReview {
  id              String   @id @default(cuid())
  projectId       String
  adminId         String?
  action          String   // submitted, under_review, approved, rejected, revision_requested
  notes           String?
  feedback        String?
  
  // Timestamps
  createdAt       DateTime @default(now())
  
  // Relationships would be added when we have the models
  @@index([projectId])
  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@map("project_reviews")
} 
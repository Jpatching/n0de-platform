{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_API_BASE_URL": "https://n0de-backend-production-4e34.up.railway.app/api/v1",
    "NEXT_PUBLIC_API_URL": "https://n0de-backend-production-4e34.up.railway.app",
    "NEXT_PUBLIC_APP_URL": "https://www.n0de.pro",
    "NEXT_PUBLIC_AUTH_URL": "https://n0de-backend-production-4e34.up.railway.app"
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "https://n0de-backend-production-4e34.up.railway.app/api/v1/$1"
    }
  ]
}
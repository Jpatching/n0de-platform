# ==============================================
# PV3 GAMING PLATFORM - ENVIRONMENT TEMPLATE
# ==============================================
# Copy this file to .env and fill in your values

# 🖥️ SERVER CONFIGURATION
NODE_ENV=development
PORT=8000

# 🗄️ DATABASE
DATABASE_URL="postgresql://username:password@hostname:port/database"

# 🌐 SOLANA CONFIGURATION
SOLANA_RPC_URL="https://api.devnet.solana.com"
PV3_PROGRAM_ID="YOUR_DEPLOYED_PROGRAM_ID_HERE"

# 🔐 WALLET CONFIGURATION
# Generate your own private keys - NEVER use production keys in development!
SOLANA_PRIVATE_KEY=[YOUR_BACKEND_WALLET_PRIVATE_KEY_ARRAY]
VERIFIER_SEED="[YOUR_VERIFIER_SEED_ARRAY]"

# 💰 PLATFORM WALLETS
# These should match your smart contract initialization
TREASURY_WALLET=YOUR_TREASURY_WALLET_PUBKEY
REFERRAL_WALLET=YOUR_REFERRAL_WALLET_PUBKEY

# 🎮 GAME CONFIGURATION
MIN_WAGER=0.1
MAX_WAGER=10.0
PLATFORM_FEE_PERCENT=0.065

# 🔒 SECURITY
JWT_SECRET="your_super_secret_jwt_key_change_in_production"

# 🤖 BOT SERVICE CONFIGURATION
ENABLE_BOTS=1,2,3,4,5,6
BOT_1_PRIVATE_KEY=your_bot_1_private_key_here
BOT_2_PRIVATE_KEY=your_bot_2_private_key_here
BOT_3_PRIVATE_KEY=your_bot_3_private_key_here
BOT_4_PRIVATE_KEY=your_bot_4_private_key_here
BOT_5_PRIVATE_KEY=your_bot_5_private_key_here
BOT_6_PRIVATE_KEY=your_bot_6_private_key_here

# 📋 SETUP INSTRUCTIONS:
# 1. Run: cp env.example .env
# 2. Generate new keypairs: solana-keygen new
# 3. Deploy smart contract with your keypairs
# 4. Update PV3_PROGRAM_ID with your deployed program
# 5. Update wallet addresses to match your deployment
# 6. Set up your PostgreSQL database
# 7. Run: npm install && npm run start:dev 
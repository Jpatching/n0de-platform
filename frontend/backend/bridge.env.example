# Bridge Service Environment Configuration
# Copy this to your .env file and update with real values

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/pv3_db"

# Solana Configuration
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
PV3_PROGRAM_ID="7KV8dJTTARc5KoDNjWpRCrVQpiuj4HoKYqTcqK2iTz8W"

# Bridge RPC Endpoints
ETHEREUM_RPC_URL="https://eth.llamarpc.com"
POLYGON_RPC_URL="https://polygon-rpc.com"
BNB_RPC_URL="https://bsc-dataseed.binance.org"

# Wormhole Configuration
WORMHOLE_NETWORK="Mainnet"
WORMHOLE_GUARDIAN_API="https://api.wormhole.com"

# Bridge Token Addresses - Ethereum
ETH_TOKEN_ADDRESS="0x0000000000000000000000000000000000000000"
USDC_ETHEREUM_ADDRESS="0xA0b86a33E6441b8C4505B7C0c6b0b8e6F6b6b6b6"
USDT_ETHEREUM_ADDRESS="0xdAC17F958D2ee523a2206206994597C13D831ec7"

# Bridge Token Addresses - Polygon
MATIC_TOKEN_ADDRESS="0x0000000000000000000000000000000000000000"
USDC_POLYGON_ADDRESS="0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174"
USDT_POLYGON_ADDRESS="0xc2132D05D31c914a87C6611C10748AEb04B58e8F"

# Bridge Token Addresses - BNB Chain
BNB_TOKEN_ADDRESS="0x0000000000000000000000000000000000000000"
USDC_BNB_ADDRESS="0x8AC76a51cc950d9822D68b83fE1Ad97B32Cd580d"
USDT_BNB_ADDRESS="0x55d398326f99059fF775485246999027B3197955"

# Bridge Configuration
BRIDGE_ENABLED=true
BRIDGE_FEE_BPS=500
BRIDGE_TREASURY_WALLET="your_bridge_treasury_wallet_here"

# PV3 Program Configuration
VERIFIER_PRIVATE_KEY="your_verifier_private_key_here"

# Bridge Configuration
BRIDGE_CONVENIENCE_FEE_BPS=500  # 5% convenience fee
BRIDGE_MAX_AMOUNT_ETH=10        # Maximum 10 ETH per transaction
BRIDGE_MAX_AMOUNT_USDC=50000    # Maximum 50,000 USDC per transaction
BRIDGE_MIN_AMOUNT_USD=10        # Minimum $10 equivalent
BRIDGE_RPC_URL="https://api.devnet.solana.com"
BRIDGE_WS_URL="wss://api.devnet.solana.com"
BRIDGE_NETWORK="devnet"
BRIDGE_COMMITMENT="confirmed"

# Monitoring Configuration
BRIDGE_MONITOR_INTERVAL_MS=15000    # Check every 15 seconds
BRIDGE_TIMEOUT_MINUTES=10           # Consider failed after 10 minutes
BRIDGE_RETRY_ATTEMPTS=3             # Retry failed transactions 3 times

# API Configuration
PORT=3001
NODE_ENV="production"
API_URL="https://api.pv3.io"

# Security
JWT_SECRET="your-super-secret-jwt-key-here"
CORS_ORIGINS="https://pv3.vercel.app,https://www.pv3.io"

# Logging
LOG_LEVEL="info"
LOG_BRIDGE_TRANSACTIONS=true
LOG_WORMHOLE_RESPONSES=false  # Set to true for debugging 